# ─────────────────────────────────────────────────────────────────────────────
# FreelanceKit — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site ─────────────────────────────────────────────────────────────────────
# Canonical URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://freelancekit.co

# ── Resend (email capture + welcome emails) ───────────────────────────────────
# Sign up at: https://resend.com (free tier: 3,000 emails/mo, 100/day)
# API key: Dashboard → API Keys → Create API Key
RESEND_API_KEY=re_your_key_here

# "From" email address. Must be from a domain verified in Resend.
NEWSLETTER_FROM_EMAIL=hello@freelancekit.co

# Audience ID for your newsletter list in Resend
# Dashboard → Audiences → Create → copy the ID
RESEND_AUDIENCE_ID=your_audience_id_here

# ── Plausible Analytics (privacy-first, no cookies) ──────────────────────────
# Sign up at: https://plausible.io or self-host
# Your site domain as registered in Plausible (e.g., freelancekit.co)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=freelancekit.co
