{
  "$schema": "https://design-tokens.org/schemas/1.0",
  "meta": {
    "project": "FreelanceKit",
    "description": "The Complete Business OS for Freelancers",
    "url": "https://freelancekit.co",
    "framework": "Next.js 14 App Router",
    "styling": "Tailwind CSS v3",
    "lastUpdated": "2026-05-25"
  },
  "color": {
    "brand": {
      "50":  { "value": "#faf5ff", "comment": "brand lightest" },
      "100": { "value": "#f3e8ff" },
      "200": { "value": "#e9d5ff" },
      "300": { "value": "#d8b4fe" },
      "400": { "value": "#c084fc" },
      "500": { "value": "#a855f7", "comment": "brand primary" },
      "600": { "value": "#9333ea", "comment": "brand default / links" },
      "700": { "value": "#7e22ce" },
      "800": { "value": "#6b21a8" },
      "900": { "value": "#581c87" },
      "950": { "value": "#3b0764", "comment": "brand darkest" }
    },
    "sand": {
      "50":  { "value": "#fdfcfb", "comment": "page background" },
      "100": { "value": "#f8f4ef", "comment": "subtle background / cards" },
      "200": { "value": "#ede8e0" },
      "300": { "value": "#ddd5c8" },
      "400": { "value": "#c8bfb0" },
      "500": { "value": "#b5a898" },
      "600": { "value": "#9c8e7e" },
      "700": { "value": "#7a6e61" },
      "800": { "value": "#5a5249", "comment": "body text / secondary" },
      "900": { "value": "#3d3830" }
    },
    "ink": { "value": "#1a1523", "comment": "primary text / headings" },
    "semantic": {
      "background":     { "value": "#fdfcfb", "token": "sand-50" },
      "foreground":     { "value": "#1a1523", "token": "ink" },
      "primary":        { "value": "#9333ea", "token": "brand-600" },
      "primaryHover":   { "value": "#7e22ce", "token": "brand-700" },
      "primaryLight":   { "value": "#f3e8ff", "token": "brand-100" },
      "bodyText":       { "value": "#5a5249", "token": "sand-800" },
      "mutedText":      { "value": "#7a6e61", "token": "sand-700" },
      "border":         { "value": "#ede8e0", "token": "sand-200" },
      "cardBackground": { "value": "#f8f4ef", "token": "sand-100" },
      "accent":         { "value": "#a855f7", "token": "brand-500" }
    }
  },
  "typography": {
    "fontFamily": {
      "display": {
        "value": "Bricolage Grotesque",
        "fallback": "system-ui, sans-serif",
        "googleFont": "https://fonts.google.com/specimen/Bricolage+Grotesque",
        "weights": [400, 500, 600, 700, 800],
        "usage": "Headings, hero text, display copy"
      },
      "body": {
        "value": "Inter",
        "fallback": "system-ui, sans-serif",
        "googleFont": "https://fonts.google.com/specimen/Inter",
        "weights": [400, 500, 600],
        "usage": "Body text, UI labels, paragraphs"
      },
      "mono": {
        "value": "Fira Code",
        "fallback": "Cascadia Code, monospace",
        "usage": "Code blocks"
      }
    },
    "scale": {
      "xs":   { "value": "0.75rem",  "px": 12 },
      "sm":   { "value": "0.875rem", "px": 14 },
      "base": { "value": "1rem",     "px": 16 },
      "lg":   { "value": "1.125rem", "px": 18 },
      "xl":   { "value": "1.25rem",  "px": 20 },
      "2xl":  { "value": "1.5rem",   "px": 24 },
      "3xl":  { "value": "1.875rem", "px": 30 },
      "4xl":  { "value": "2.25rem",  "px": 36 },
      "5xl":  { "value": "3rem",     "px": 48 },
      "6xl":  { "value": "3.75rem",  "px": 60 }
    },
    "lineHeight": {
      "tight":  { "value": 1.25 },
      "snug":   { "value": 1.375 },
      "normal": { "value": 1.5 },
      "relaxed":{ "value": 1.625 }
    }
  },
  "spacing": {
    "scale": "4px base unit (Tailwind default)",
    "values": {
      "1":  "4px",  "2": "8px",   "3": "12px", "4": "16px",
      "5":  "20px", "6": "24px",  "8": "32px", "10": "40px",
      "12": "48px", "16": "64px", "20": "80px","24": "96px"
    },
    "semantic": {
      "sectionPaddingY": "80px (py-20)",
      "containerPaddingX": "24px (px-6)",
      "cardPadding": "24px (p-6)",
      "componentGap": "16px (gap-4)"
    }
  },
  "effects": {
    "borderRadius": {
      "sm":   "0.125rem",
      "md":   "0.375rem",
      "lg":   "0.5rem",
      "xl":   "0.75rem",
      "2xl":  "1rem",
      "full": "9999px"
    },
    "shadow": {
      "sm":  "0 1px 2px 0 rgb(0 0 0 / 0.05)",
      "md":  "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
      "lg":  "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
      "xl":  "0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1)"
    },
    "animation": {
      "fadeUp": "fadeUp 0.5s ease-out forwards",
      "fadeIn": "fadeIn 0.4s ease-out forwards",
      "delays": ["100ms", "200ms", "300ms", "400ms", "500ms"]
    }
  },
  "brand": {
    "personality": ["modern", "premium", "warm", "minimal", "trustworthy"],
    "audience": "Freelancers and independent consultants",
    "tone": "Professional yet approachable. Confident without being corporate.",
    "style": "Clean, warm minimalism with purposeful purple accents on a sand/cream base",
    "antiPatterns": [
      "Cold blue/grey corporate palettes",
      "Cluttered layouts",
      "Aggressive sales copy",
      "Dark mode as default"
    ]
  },
  "components": {
    "button": {
      "primary": {
        "background": "#9333ea",
        "text": "#ffffff",
        "hover": "#7e22ce",
        "borderRadius": "0.5rem",
        "padding": "12px 24px",
        "fontFamily": "Inter",
        "fontWeight": 600,
        "fontSize": "0.875rem"
      },
      "secondary": {
        "background": "transparent",
        "border": "1px solid #ddd5c8",
        "text": "#1a1523",
        "hover": "#f8f4ef",
        "borderRadius": "0.5rem"
      },
      "ghost": {
        "background": "transparent",
        "text": "#9333ea",
        "hover": "#f3e8ff"
      }
    },
    "card": {
      "background": "#f8f4ef",
      "border": "1px solid #ede8e0",
      "borderRadius": "0.75rem",
      "padding": "24px",
      "shadow": "0 1px 2px 0 rgb(0 0 0 / 0.05)"
    },
    "badge": {
      "default": { "background": "#f3e8ff", "text": "#6b21a8" },
      "muted":   { "background": "#ede8e0", "text": "#5a5249" }
    }
  }
}
